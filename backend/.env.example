# --- Database (Supabase -> Project Settings -> Database -> connection pooler URI) ---
# Note the +asyncpg driver segment.
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# --- Supabase ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>          # server-only, never ships to the browser
SUPABASE_JWT_SECRET=<jwt-secret>                      # Project Settings -> API -> JWT Secret

# --- AI ---
GEMINI_API_KEY=<gemini-api-key>
GEMINI_AGENT_MODEL=gemini-2.5-flash
GEMINI_SUMMARY_MODEL=gemini-2.5-flash
# Embeddings are truncated to EMBEDDING_DIMENSIONS (768) to match the DB column, so either
# text-embedding-004 (native 768) or gemini-embedding-001 (native 3072, truncated) works.
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# --- Transcription: deepgram (diarization) | whisper (fallback, no diarization) ---
TRANSCRIPTION_PROVIDER=deepgram
DEEPGRAM_API_KEY=<deepgram-key>
OPENAI_API_KEY=                                       # only if TRANSCRIPTION_PROVIDER=whisper

# --- App ---
ENVIRONMENT=development
FRONTEND_ORIGIN=http://localhost:5173
